                      </object>
                    </child>
                    <child>
                      <object class="GtkBox">
                        <property name="margin-bottom">5</property>
                        <child>
                          <object class="GtkLabel">
                            <property name="label">Album Title: </property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel" id="settings-dump-overlay-title">
                            <property name="ellipsize">end</property>
                            <property name="halign">end</property>
                            <property name="hexpand">True</property>
                            <property name="max-width-chars">20</property>
                            <property name="width-chars">20</property>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox">
                        <property name="margin-bottom">5</property>
                        <child>
                          <object class="GtkLabel">
                            <property name="label">Tracks: </property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel" id="settings-dump-overlay-tracks">
                            <property name="halign">end</property>
                            <property name="hexpand">True</property>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox">
                        <child>
                          <object class="GtkButton" id="dump-cancel-button">
                            <property name="css-classes">box-button</property>
                            <property name="halign">center</property>
                            <property name="hexpand">True</property>
                            <property name="label">Cancel</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkButton" id="dump-accept-button">
                            <property name="css-classes">box-button</property>
                            <property name="halign">center</property>
                            <property name="hexpand">True</property>
                            <property name="label">Dump</property>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkSeparator">
                        <property name="height-request">5</property>
                        <property name="margin-bottom">15</property>
                        <property name="margin-top">15</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel">
                        <property name="css-classes">progress-text</property>
                        <property name="halign">center</property>
                        <property name="height-request">20</property>
                        <property name="label">Song Progress</property>
                        <property name="margin-top">5</property>
                        <property name="valign">center</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkProgressBar" id="dump-song-progress">
                        <property name="text">Song Progress 0%</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel">
                        <property name="css-classes">progress-text</property>
                        <property name="label">Disc Progress</property>
                        <property name="margin-top">15</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkProgressBar" id="dump-disc-progress">
                        <property name="margin-bottom">10</property>
                        <property name="text">Disc Progress 0/0</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child type="overlay">
                  <object class="GtkBox" id="setting-cd-info-overlay">
                    <property name="css-classes">overlay</property>
                    <property name="opacity">0.0</property>
                    <property name="orientation">vertical</property>
                    <property name="visible">False</property>
                    <child>
                      <object class="GtkLabel" id="cd-info-album-name">
                        <property name="label">&lt;Album Name&gt;</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkSeparator">
                        <property name="height-request">4</property>
                        <child>
                          <object class="GtkBox">
                            <child>
                              <object class="GtkLabel">
                                <property name="label">Artist:</property>
                              </object>
                            </child>
                            <child>
                              <object class="GtkLabel">
                                <property name="halign">end</property>
                                <property name="hexpand">True</property>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox">
                        <child>
                          <object class="GtkLabel">
                            <property name="label">Artist:</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel" id="cd-info-artist-name">
                            <property name="halign">end</property>
                            <property name="hexpand">True</property>
                            <property name="label">&lt;Artist Name&gt;</property>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox">
                        <child>
                          <object class="GtkLabel">
                            <property name="label">Tracks:</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel" id="cd-info-track-count">
                            <property name="halign">end</property>
                            <property name="hexpand">True</property>
                            <property name="label">&lt;Track Num&gt;</property>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox">
                        <child>
                          <object class="GtkLabel">
                            <property name="label">Length:</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel" id="cd-info-length">
                            <property name="halign">end</property>
                            <property name="hexpand">True</property>
                            <property name="label">&lt;Album Length&gt;</property>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox">
                        <child>
                          <object class="GtkLabel">
                            <property name="label">Release:</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel" id="cd-info-release-date">
                            <property name="halign">end</property>
                            <property name="hexpand">True</property>
                            <property name="label">&lt;Release Year&gt;</property>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkImage" id="cd-info-album-art">
                        <property name="file">res/logo.jpg</property>
                        <property name="icon-size">large</property>
                        <property name="margin-top">10</property>
                        <property name="pixel-size">200</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child type="overlay">
                  <object class="GtkBox" id="setting-output-overlay">
                    <property name="css-classes">overlay</property>
                    <property name="margin-end">100</property>
                    <property name="margin-start">100</property>
                    <property name="opacity">0.0</property>
                    <property name="orientation">vertical</property>
                    <property name="valign">center</property>
                    <property name="vexpand">True</property>
                    <property name="visible">False</property>
                    <child>
                      <object class="GtkLabel">
                        <property name="css-classes">overlay-label</property>
                        <property name="justify">center</property>
                        <property name="label">Output Select</property>
                        <property name="margin-bottom">5</property>
                        <property name="margin-top">5</property>
                      </object>
                    </child>
                    <child type="overlay">
                      <object class="GtkListBox" id="setting-output-overlay-list">
                        <property name="css-classes">overlay-list</property>
                        <property name="hexpand">True</property>
                        <property name="valign">center</property>
                        <child>
                          <object class="GtkButton">
                            <property name="label">Speakers</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkButton">
                            <property name="label">Headphones</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkButton">
                            <property name="label">USB Headset</property>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
                <child type="overlay">
                  <object class="GtkBox" id="setting-volume-overlay">
                    <property name="css-classes">overlay</property>
                    <property name="opacity">0.0</property>
                    <property name="orientation">vertical</property>
                    <property name="overflow">hidden</property>
                    <property name="valign">center</property>
                    <property name="visible">False</property>
                    <child>
                      <object class="GtkLabel">
                        <property name="css-classes">overlay-label</property>
                        <property name="halign">center</property>
                        <property name="hexpand">True</property>
                        <property name="justify">center</property>
                        <property name="label">Volume</property>
                        <property name="margin-top">20</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkProgressBar" id="setting-volume-progress">
                        <property name="can-focus">False</property>
                        <property name="can-target">False</property>
                        <property name="focus-on-click">False</property>
                        <property name="hexpand">True</property>
                        <property name="margin-bottom">20</property>
                        <property name="margin-end">20</property>
                        <property name="margin-start">40</property>
                        <property name="margin-top">20</property>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </property>
            <property name="name">setting-screen</property>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
